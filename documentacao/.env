# ============================================================
# Configuração do Assistente de IA (opcional)
# ------------------------------------------------------------
# Preencha AI_KEY para usar o modo IA sem digitar a chave na tela.
# Quando AI_KEY estiver preenchida aqui, a configuração de chave
# some das Configurações (⚙️) do assistente.
#
# IMPORTANTE: este arquivo é lido pelo navegador via fetch — só
# funciona quando o site é servido por um servidor (ex.: o docs
# server em http://localhost:8099). Abrindo o index.html direto
# pelo file:// o .env é ignorado e volta a config manual na tela.
# ============================================================

# Provedor: anthropic  ou  gemini
AI_PROVIDER=

# Chave da API (Anthropic sk-ant-...  |  Google AI Studio AIza...)
AI_KEY=

# Modelo (opcional). Ex.: claude-haiku-4-5-20251001 | claude-sonnet-5 | gemini-2.5-flash | gemini-3.5-pro
AI_MODEL=
